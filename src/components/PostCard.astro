---
import type { InferEntrySchema } from 'astro:content';
import { Image } from 'astro:assets';
import type { NavigationItem } from '@utils/types';
import { generateTagItem } from '@utils/scripts';

interface Props {
  postMeta: InferEntrySchema<'posts'>;
  index: number;
}

const { postMeta, index }: Props = Astro.props;

const postLink: string = `/posts/${postMeta.slug}`;
const tags: NavigationItem[] = postMeta.tags.map((tag: string) =>
  generateTagItem(tag)
);
const loadingSchema: 'eager' | 'lazy' = index > 0 ? 'lazy' : 'eager';
---

<article class="post-card-wrapper">
  <div>
    <a href={postLink} tabindex={-1}>
      <Image
        class="featured-image image--default"
        src={postMeta.image.url}
        alt={postMeta.image.alt}
        width="800"
        height="800"
        decoding="async"
        loading={loadingSchema}
      />
    </a>
  </div>
  <header class="title-wrapper">
    <h2 class="heading font-normal">
      <a class="link--primary" href={postLink}>{postMeta.title}</a>
    </h2>
    <div class="meta">
      <div>
        <p class="meta__date font-uppercase">
          {postMeta.datePublished}
        </p>
      </div>
      <div>
        <ul class="meta__tags" role="list">
          {
            tags.map((tag: NavigationItem) => (
              <li>
                <a
                  class="meta__tags__item link--secondary font-uppercase"
                  href={`/tags/${tag.url}`}
                >
                  {tag.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </header>
  <div class="excerpt font-normal">
    <p>
      {postMeta.excerpt}
    </p>
  </div>
  <div>
    <a class="read-more link--secondary font-uppercase" href={postLink}
      >Read more</a
    >
  </div>
</article>

<style lang="scss">
  .post-card-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-15-20);
  }

  .featured-image {
    width: 100%;
    height: auto;
    aspect-ratio: auto;
    transition: opacity 0.3s;

    &:hover,
    &:focus {
      opacity: 0.8;
    }
  }

  .title-wrapper {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .heading {
    font-size: var(--font-size-xl);
    font-weight: 400;
    line-height: 165%;
  }

  .meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-30-40);

    @media only screen and (width <= 768px) {
      flex-direction: column;
      gap: 10px;
      align-items: flex-start;
    }

    &__date {
      font-size: var(--font-size-2xs);
      color: var(--color-secondary);
    }

    &__tags {
      display: flex;
      align-items: center;
      gap: var(--space-15-20);
      row-gap: 10px;
      flex-wrap: wrap;

      &__item {
        font-size: var(--font-size-2xs);
      }
    }
  }

  .excerpt {
    font-size: var(--font-size-s);
    font-weight: 300;
    line-height: 165%;
  }

  .read-more {
    font-size: var(--font-size-2xs);
  }
</style>
