---
import type { PageTitle } from '@utils/types';
import { Image } from 'astro:assets';
import heroImage from '@assets/hero-image.jpg';

interface Props {
  hasImage: boolean;
  title: PageTitle;
  meta?: string | undefined;
}

const { hasImage, title, meta } = Astro.props;
---

<Fragment>
  {
    hasImage ? (
      <div>
        <Image
          slot="image"
          class="hero-image"
          src={heroImage}
          alt="Website hero banner depicting flowers"
          width="1160"
          height="580"
          decoding="async"
          loading="eager"
        />
      </div>
    ) : null
  }
  <div class="title">
    <h1 class="title__heading font-normal">
      {title.heading}
    </h1>
    <h2 class="title__subheading font-normal">
      {title.subheading}
    </h2>
    {
      meta !== undefined ? (
        <p class="title__meta font-uppercase">{meta}</p>
      ) : null
    }
  </div>
</Fragment>

<style lang="scss">
  .title {
    display: flex;
    flex-direction: column;
    gap: var(--space-15-20);
    padding-bottom: var(--space-60-80);
    border-bottom: var(--color-bg-secondary) solid 1px;

    &__heading {
      max-width: 75%;
      font-size: var(--font-size-2xl);
      font-weight: 400;
      line-height: 165%;

      @media only screen and (width <= 768px) {
        max-width: 100%;
      }
    }

    &__subheading {
      max-width: 50%;
      font-size: var(--font-size-m);
      font-weight: 300;
      line-height: 165%;

      @media only screen and (width <= 768px) {
        max-width: 100%;
      }
    }

    &__meta {
      font-size: var(--font-size-2xs);
      color: var(--color-secondary);
    }
  }
</style>
